{
  "name": "fleetsmith",
  "version": "0.2.0",
  "description": "Meta agent-fleet builder: compile one fleet spec into coordinated agent teams, skills, and handover protocols for Claude Code, opencode, and goose.",
  "type": "module",
  "bin": {
    "fleetsmith": "./src/cli.js"
  },
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./adapters": "./src/adapters/index.js",
    "./spec": "./src/spec/index.js"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test",
    "bundle": "node scripts/bundle.mjs",
    "build:binary": "node scripts/bundle.mjs && node scripts/build-binary.mjs",
    "build:example": "node src/cli.js build fleet.example.yaml --target all --out ./dist-example",
    "prepublishOnly": "node --test"
  },
  "keywords": [
    "agents",
    "multi-agent",
    "claude-code",
    "opencode",
    "goose",
    "agent-skills",
    "harness",
    "orchestration"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/subhransusekhar/fleetsmith.git"
  },
  "homepage": "https://github.com/subhransusekhar/fleetsmith#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "postject": "^1.0.0-alpha.6"
  }
}
